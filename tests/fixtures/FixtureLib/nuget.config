<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="../../../artifacts/packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <!-- The floating AgentSkills.Sdk reference must always resolve from the
       freshly packed local feed - never from a published package, which would
       silently swap the bits under test after the first real release. -->
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="AgentSkills.Sdk" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
