<Project>
  <!-- Generated by AgentSkills.Sdk for FixtureLib 1.0.0. Do not edit.
       Syncs the packaged agent skill into the consumer workspace when the
       Consumer Flag $(FixtureLibAgentSkills) opts in. Everything here evaluates on the
       consumer's machine; nothing was expanded at pack time except the
       fixturelib_1_0_0 name suffix, the skill name and the token map. -->

  <Target Name="AgentSkillsSync_fixturelib_1_0_0"
          BeforeTargets="BeforeBuild"
          Condition="'$(FixtureLibAgentSkills)' != '' AND '$(DesignTimeBuild)' != 'true'">

    <!-- 1. Workspace Root (ADR-0007): AgentSkillsRoot → SolutionDir → .git walk-up → project dir. -->
    <PropertyGroup>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(AgentSkillsRoot)' != ''">$([MSBuild]::EnsureTrailingSlash('$(AgentSkillsRoot)'))</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND '$(SolutionDir)' != '' AND '$(SolutionDir)' != '*Undefined*'">$([MSBuild]::EnsureTrailingSlash('$(SolutionDir)'))</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/.git')">$(MSBuildProjectDirectory)/</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../.git')">$(MSBuildProjectDirectory)/../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../.git')">$(MSBuildProjectDirectory)/../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../../.git')">$(MSBuildProjectDirectory)/../../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../../../.git')">$(MSBuildProjectDirectory)/../../../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../../../../.git')">$(MSBuildProjectDirectory)/../../../../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../../../../../.git')">$(MSBuildProjectDirectory)/../../../../../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == '' AND Exists('$(MSBuildProjectDirectory)/../../../../../../../.git')">$(MSBuildProjectDirectory)/../../../../../../../</_AgsRoot_fixturelib_1_0_0>
      <_AgsFallback_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == ''">true</_AgsFallback_fixturelib_1_0_0>
      <_AgsRoot_fixturelib_1_0_0 Condition="'$(_AgsRoot_fixturelib_1_0_0)' == ''">$(MSBuildProjectDirectory)/</_AgsRoot_fixturelib_1_0_0>
    </PropertyGroup>
    <Warning Code="AGSK102" Condition="'$(_AgsFallback_fixturelib_1_0_0)' == 'true'"
             Text="[FixtureLib] No AgentSkillsRoot, SolutionDir or .git found; skills placed next to the project." />

    <!-- 2. Agent Token → destination map (ADR-0005): exact match, case-insensitive,
         duplicates collapse; tokens with a path separator are custom destinations. -->
    <ItemGroup>
      <_AgsTokensRaw_fixturelib_1_0_0 Include="$(FixtureLibAgentSkills)" />
      <!-- Lowercased per item: a property-function result is escaped, so
           $(FixtureLibAgentSkills.ToLowerInvariant()) would not split on semicolons. -->
      <_AgsTokensNorm_fixturelib_1_0_0 Include="$([System.String]::Copy('%(_AgsTokensRaw_fixturelib_1_0_0.Identity)').ToLowerInvariant())" />
      <_AgsDest_fixturelib_1_0_0 Include=".agents/skills" Variant="agents"
                Condition="'@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'universal'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'opencode'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'codex'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'cursor'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'gemini-cli'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'github-copilot'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'amp'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'cline'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'zed'))' == 'true' Or '@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'warp'))' == 'true'" />
      <_AgsDest_fixturelib_1_0_0 Include=".claude/skills" Variant="claude"
                Condition="'@(_AgsTokensNorm_fixturelib_1_0_0->AnyHaveMetadataValue('Identity', 'claude-code'))' == 'true'" />
      <_AgsDest_fixturelib_1_0_0 Include="%(_AgsTokensRaw_fixturelib_1_0_0.Identity)" Variant="agents"
                Condition="$([System.String]::Copy('%(_AgsTokensRaw_fixturelib_1_0_0.Identity)').Contains('/')) Or $([System.String]::Copy('%(_AgsTokensRaw_fixturelib_1_0_0.Identity)').Contains('\'))" />
    </ItemGroup>
    <Warning Code="AGSK101"
             Text="[FixtureLib] Unknown Agent Token '%(_AgsTokensNorm_fixturelib_1_0_0.Identity)' skipped."
             Condition="'%(Identity)' != 'universal' And '%(Identity)' != 'opencode' And '%(Identity)' != 'codex' And '%(Identity)' != 'cursor' And '%(Identity)' != 'gemini-cli' And '%(Identity)' != 'github-copilot' And '%(Identity)' != 'amp' And '%(Identity)' != 'cline' And '%(Identity)' != 'zed' And '%(Identity)' != 'warp' And '%(Identity)' != 'claude-code' And !$([System.String]::Copy('%(Identity)').Contains('/')) And !$([System.String]::Copy('%(Identity)').Contains('\'))" />

    <!-- 3. Per-destination sync (ADR-0008): no-op once the Version Stamp exists —
         the directory name is version-unique and its content immutable. The stamp
         is written last so an interrupted sync re-runs.
         The batched includes below run once per destination (stamp checked per
         destination) and expand the full payload into per-destination copy items;
         a single cross-batched Copy would put _AgsDest and payload metadata in
         disjoint buckets and copy nothing. -->
    <ItemGroup>
      <_AgsPayload_fixturelib_1_0_0 Include="$(MSBuildThisFileDirectory)../agent-assets/payload/**/*" />
      <_AgsCopy_fixturelib_1_0_0 Include="@(_AgsPayload_fixturelib_1_0_0)" AgsDest="%(_AgsDest_fixturelib_1_0_0.Identity)"
          Condition="!Exists('$(_AgsRoot_fixturelib_1_0_0)%(_AgsDest_fixturelib_1_0_0.Identity)/use-fixturelib-v1-0-0/.agentskills-stamp')" />
      <_AgsSkill_fixturelib_1_0_0 Include="$(MSBuildThisFileDirectory)../agent-assets/SKILL.%(_AgsDest_fixturelib_1_0_0.Variant).md" AgsDest="%(_AgsDest_fixturelib_1_0_0.Identity)"
          Condition="!Exists('$(_AgsRoot_fixturelib_1_0_0)%(_AgsDest_fixturelib_1_0_0.Identity)/use-fixturelib-v1-0-0/.agentskills-stamp')" />
      <!-- The synced directory gitignores itself. Both markers ship as packed
           files and arrive via Copy: unlike WriteLinesToFile, Copy retries and
           skips identical content, which makes concurrent first syncs safe. -->
      <_AgsGitignore_fixturelib_1_0_0 Include="$(MSBuildThisFileDirectory)../agent-assets/skill.gitignore" AgsDest="%(_AgsDest_fixturelib_1_0_0.Identity)"
          Condition="!Exists('$(_AgsRoot_fixturelib_1_0_0)%(_AgsDest_fixturelib_1_0_0.Identity)/use-fixturelib-v1-0-0/.agentskills-stamp')" />
      <_AgsStamp_fixturelib_1_0_0 Include="$(MSBuildThisFileDirectory)../agent-assets/skill.stamp" AgsDest="%(_AgsDest_fixturelib_1_0_0.Identity)"
          Condition="!Exists('$(_AgsRoot_fixturelib_1_0_0)%(_AgsDest_fixturelib_1_0_0.Identity)/use-fixturelib-v1-0-0/.agentskills-stamp')" />
    </ItemGroup>

    <Copy SourceFiles="@(_AgsCopy_fixturelib_1_0_0)"
          DestinationFiles="@(_AgsCopy_fixturelib_1_0_0->'$(_AgsRoot_fixturelib_1_0_0)%(AgsDest)/use-fixturelib-v1-0-0/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" Retries="3" RetryDelayMilliseconds="200"
          Condition="'@(_AgsDest_fixturelib_1_0_0)' != '' AND '@(_AgsCopy_fixturelib_1_0_0)' != ''" />

    <Copy SourceFiles="@(_AgsSkill_fixturelib_1_0_0)"
          DestinationFiles="@(_AgsSkill_fixturelib_1_0_0->'$(_AgsRoot_fixturelib_1_0_0)%(AgsDest)/use-fixturelib-v1-0-0/SKILL.md')"
          SkipUnchangedFiles="true" Retries="3" RetryDelayMilliseconds="200"
          Condition="'@(_AgsDest_fixturelib_1_0_0)' != '' AND '@(_AgsSkill_fixturelib_1_0_0)' != ''" />

    <Copy SourceFiles="@(_AgsGitignore_fixturelib_1_0_0)"
          DestinationFiles="@(_AgsGitignore_fixturelib_1_0_0->'$(_AgsRoot_fixturelib_1_0_0)%(AgsDest)/use-fixturelib-v1-0-0/.gitignore')"
          SkipUnchangedFiles="true" Retries="3" RetryDelayMilliseconds="200"
          Condition="'@(_AgsDest_fixturelib_1_0_0)' != '' AND '@(_AgsGitignore_fixturelib_1_0_0)' != ''" />

    <!-- Stamp lands last so an interrupted sync re-runs (ADR-0008). -->
    <Copy SourceFiles="@(_AgsStamp_fixturelib_1_0_0)"
          DestinationFiles="@(_AgsStamp_fixturelib_1_0_0->'$(_AgsRoot_fixturelib_1_0_0)%(AgsDest)/use-fixturelib-v1-0-0/.agentskills-stamp')"
          SkipUnchangedFiles="true" Retries="3" RetryDelayMilliseconds="200"
          Condition="'@(_AgsDest_fixturelib_1_0_0)' != '' AND '@(_AgsStamp_fixturelib_1_0_0)' != ''" />

  </Target>
</Project>
